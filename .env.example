### Strava OAuth (Step 7 — Tier 1 Garmin integration via Strava). Register
### an app at https://www.strava.com/settings/api with Authorization
### Callback Domain = "localhost" for dev, or your deploy host for prod.

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Full URL — must match the registered callback domain exactly.
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
# 32+ random bytes (hex). Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STRAVA_COOKIE_SECRET=

### Supabase (Step 11a — opt-in cloud backup + magic-link auth).
### Create a project at https://supabase.com, then copy the values from
### Project Settings → API. Run the SQL in supabase/migrations/0001_backups.sql
### in the SQL editor to create the `backups` table + RLS policy.
###
### The publishable (anon) key is safe to expose in the client bundle — RLS
### on the `backups` table enforces per-user isolation. The service-role key
### is NOT used in 11a; it'll arrive in 11b for the push-dispatch cron route.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
