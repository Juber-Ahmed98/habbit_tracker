### Strava OAuth (Step 7 — Tier 1 Garmin integration via Strava). Register
### an app at https://www.strava.com/settings/api with Authorization
### Callback Domain = "localhost" for dev, or your deploy host for prod.

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Full URL — must match the registered callback domain exactly.
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
# 32+ random bytes (hex). Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STRAVA_COOKIE_SECRET=
